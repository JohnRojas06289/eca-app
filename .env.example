EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://TU_IP_LOCAL:4000

# Demo solo para desarrollo o para desplegar frontend sin backend.
# En producción real, configura API_BASE_URL y pon estos valores en false.
EXPO_PUBLIC_ENABLE_DEMO_LOGIN=true
EXPO_PUBLIC_USE_DEMO_AUTH=true
EXPO_PUBLIC_ENABLE_DEMO_CHAT=true
